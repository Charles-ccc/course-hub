{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm build && concurrently -k -n TSC,API -c yellow,cyan \"pnpm:dev:build\" \"pnpm:dev:start\"",
    "dev:build": "tsc -w -p tsconfig.build.json --preserveWatchOutput",
    "dev:start": "node --watch dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "tsx --test src/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:rename:insitution": "prisma db execute --schema prisma/schema.prisma --file prisma/rename-to-insitution.sql",
    "db:add:staff": "prisma db execute --schema prisma/schema.prisma --file prisma/add-staff.sql",
    "db:add:audit": "prisma db execute --schema prisma/schema.prisma --file prisma/add-audit-log.sql",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.8",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prisma": "^6.9.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
