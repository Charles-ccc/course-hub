generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  PLATFORM_ADMIN
}

enum InsitutionStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXITED
}

enum InsitutionUserRole {
  INSITUTION_ADMIN
}

enum CourseStatus {
  ONLINE
  OFFLINE
}

enum CourseAuditStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum SalesmanStatus {
  ACTIVE
  DISABLED
}

enum ContractType {
  EMPLOYEE
  AGENT
}

enum RealnameStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum OrderStatus {
  CREATED
  COOLING_OFF
  ACTIVE
  COMPLETED
  REFUNDED
  TERMINATED
}

enum PeriodStatus {
  PENDING
  DELIVERED
  PAID
  OVERDUE
  WRITTEN_OFF
}

enum SettlementStatus {
  PENDING
  SETTLED
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
}

enum CommissionType {
  CLOSING
  PERFORMANCE
}

enum CommissionStatus {
  PENDING
  SETTLED
  HELD
  CLAWED_BACK
}

enum PayType {
  DEFERRED
  IMMEDIATE
}

enum OrgCodeStatus {
  ACTIVE
  DISABLED
}

model AdminUser {
  id           String    @id
  username     String    @unique
  displayName  String
  passwordHash String
  role         AdminRole @default(PLATFORM_ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  refreshTokens RefreshToken[]
}

model Insitution {
  id                        String              @id
  name                      String
  socialCreditCode          String              @unique
  settlementRate            Decimal             @db.Decimal(5, 2)
  depositBalanceCents       Int
  cumulativeGmvCents        Int
  cumulativeServiceFeeCents Int
  status                    InsitutionStatus
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  users                     InsitutionUser[]
  courses                   Course[]
  salesmen                  Salesman[]
  students                  Student[]
  orders                    Order[]
  settlements               SettlementRecord[]
  questions                 Question[]
  orgCodes                  OrgCode[]
}

model InsitutionUser {
  id           String              @id
  phone        String              @unique
  displayName  String
  passwordHash String
  role         InsitutionUserRole @default(INSITUTION_ADMIN)
  insitutionId String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  insitution  Insitution         @relation(fields: [insitutionId], references: [id])
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id                 String             @id
  userId             String
  role               String
  tokenHash          String
  status             RefreshTokenStatus @default(ACTIVE)
  expiresAt          DateTime
  revokedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  adminUserId        String?
  insitutionUserId  String?
  salesmanId         String?
  studentId          String?
  adminUser          AdminUser?         @relation(fields: [adminUserId], references: [id])
  insitutionUser    InsitutionUser?   @relation(fields: [insitutionUserId], references: [id])
  salesman           Salesman?         @relation(fields: [salesmanId], references: [id])
  student            Student?          @relation(fields: [studentId], references: [id])

  @@index([userId, role, status])
}

model Course {
  id             String            @id
  insitutionId  String
  name           String
  description    String
  instructorInfo String
  outline        String?           @db.Text
  teacherContact String?
  priceCents     Int
  periodCount    Int
  status         CourseStatus
  auditStatus    CourseAuditStatus @default(APPROVED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  insitution    Insitution       @relation(fields: [insitutionId], references: [id])
  orders         Order[]
  videos         CourseVideo[]
}

model Salesman {
  id                        String        @id
  insitutionId             String
  username                  String        @unique
  passwordHash              String
  name                      String
  phone                     String        @unique
  contractType              ContractType
  groupName                 String?
  status                    SalesmanStatus
  studentCount              Int           @default(0)
  cumulativeCommissionCents Int           @default(0)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  insitution               Insitution   @relation(fields: [insitutionId], references: [id])
  students                  Student[]
  commissions               Commission[]
  refreshTokens             RefreshToken[]
  orgCodes                  OrgCode[]
}

model Student {
  id               String         @id
  insitutionId    String
  orgCodeId        String?
  boundSalesmanId  String?
  name             String?
  phone            String         @unique
  alipayOpenId     String?        @unique
  realnameStatus   RealnameStatus @default(UNVERIFIED)
  boundAt          DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  insitution      Insitution    @relation(fields: [insitutionId], references: [id])
  orgCode          OrgCode?       @relation(fields: [orgCodeId], references: [id])
  boundSalesman    Salesman?      @relation(fields: [boundSalesmanId], references: [id])
  orders           Order[]
  realnameRecords  RealnameRecord[]
  refreshTokens    RefreshToken[]
  signRecords      SignRecord[]
  checkinRecords   CheckinRecord[]

  @@index([insitutionId])
  @@index([boundSalesmanId])
}

model Order {
  id               String      @id
  insitutionId    String
  studentId        String?
  courseId         String?
  orgCodeId        String?
  studentName      String
  courseName       String
  totalAmountCents Int
  periodCount      Int
  payType          PayType     @default(DEFERRED)
  status           OrderStatus
  coolingOffEndAt  DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  insitution      Insitution @relation(fields: [insitutionId], references: [id])
  student          Student?    @relation(fields: [studentId], references: [id])
  course           Course?     @relation(fields: [courseId], references: [id])
  orgCode          OrgCode?    @relation(fields: [orgCodeId], references: [id])
  installments     Installment[]
  commissions      Commission[]
  signRecords      SignRecord[]
  checkinRecords   CheckinRecord[]
}

model Commission {
  id          String           @id
  staffId     String
  orderId     String?
  type        CommissionType
  periodNo    Int?
  status      CommissionStatus
  amountCents Int
  studentName String
  courseName  String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  staff       Salesman         @relation(fields: [staffId], references: [id])
  order       Order?           @relation(fields: [orderId], references: [id])

  @@index([staffId, status])
  @@index([createdAt])
}

model Installment {
  id                  String       @id
  orderId             String
  periodNo            Int
  dueDate             DateTime
  plannedAmountCents  Int
  paidAmountCents     Int          @default(0)
  contentDeliveredAt  DateTime?
  status              PeriodStatus
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  order               Order        @relation(fields: [orderId], references: [id])

  @@unique([orderId, periodNo])
}

model SettlementRecord {
  id              String           @id
  insitutionId   String
  period          String
  gmvCents        Int
  serviceFeeCents Int
  status          SettlementStatus
  settledAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  insitution     Insitution      @relation(fields: [insitutionId], references: [id])

  @@unique([insitutionId, period])
}

model Question {
  id            String      @id
  insitutionId String
  studentName   String
  content       String
  askedAt       DateTime    @default(now())
  replied       Boolean     @default(false)
  replyContent  String?
  repliedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  insitution   Insitution @relation(fields: [insitutionId], references: [id])
}

model OrgCode {
  id           String        @id
  insitutionId String
  salesmanId   String?
  code         String        @unique
  status       OrgCodeStatus @default(ACTIVE)
  usedCount    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  insitution  Insitution   @relation(fields: [insitutionId], references: [id])
  salesman     Salesman?    @relation(fields: [salesmanId], references: [id])
  students     Student[]
  orders       Order[]
}

model RealnameRecord {
  id         String         @id
  studentId  String
  certifyId  String         @unique
  status     RealnameStatus
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  student    Student        @relation(fields: [studentId], references: [id])
}

model CourseVideo {
  id          String   @id
  courseId    String
  title       String
  videoKey    String
  durationSec Int      @default(0)
  sortOrder   Int      @default(0)
  isTrial     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id])
}

model SignRecord {
  id        String   @id
  studentId String
  orderId   String
  certifyId String   @unique
  signedAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])
}

model CheckinRecord {
  id         String   @id
  studentId  String
  orderId    String
  certifyId  String   @unique
  checkedAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  student    Student  @relation(fields: [studentId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
}

model SystemConfig {
  key             String   @id
  priceLimitCents Int
  minAge          Int
  maxAge          Int
  zhimaEnabled    Boolean
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ApiAuditLog {
  id           String   @id
  requestId    String
  method       String
  path         String
  ip           String
  userAgent    String
  status       Int
  latencyMs    Int
  success      Boolean
  userId       String?
  role         String?
  errorName    String?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([requestId])
  @@index([path, createdAt])
  @@index([userId, createdAt])
}