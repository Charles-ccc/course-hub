# 数据库
DATABASE_URL="mysql://root:password@localhost:3306/wangke"
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="7d"

# 微信小程序
WECHAT_STUDENT_APP_ID="wx_student_appid"
WECHAT_STUDENT_APP_SECRET="wx_student_secret"
WECHAT_STAFF_APP_ID="wx_staff_appid"
WECHAT_STAFF_APP_SECRET="wx_staff_secret"

# 支付宝小程序
ALIPAY_STUDENT_APP_ID="alipay_student_appid"
ALIPAY_STAFF_APP_ID="alipay_staff_appid"
ALIPAY_PRIVATE_KEY="your_alipay_private_key"
ALIPAY_PUBLIC_KEY="alipay_public_key"

# 实名认证 (公安部四要素)
REALNAME_API_URL="https://api.realname-service.com"
REALNAME_API_KEY="your_realname_key"

# 电子合同 (法大大/e签宝)
ESIGN_APP_ID="your_esign_app_id"
ESIGN_APP_SECRET="your_esign_secret"
ESIGN_BASE_URL="https://openapi.esign.cn"

# 阿里云 VOD
ALI_VOD_ACCESS_KEY_ID="your_access_key"
ALI_VOD_ACCESS_KEY_SECRET="your_secret"
ALI_VOD_REGION="cn-shanghai"

# 短信
SMS_ACCESS_KEY_ID="your_sms_key"
SMS_SIGN_NAME="网课超市"

# 易宝支付 (代扣)
YEEPAY_APP_KEY="your_yeepay_key"
YEEPAY_MERCHANT_NO="your_merchant_no"

# 芝麻信用 (预留, 默认关闭)
ZHIMA_APP_ID=""
ZHIMA_ENABLED="false"
